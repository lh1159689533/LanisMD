{
  "identifier": "default",
  "description": "Default capabilities for LanisMD",
  "windows": ["main", "file-preview-*"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-watch",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-unwatch",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }, { "path": "**" }]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$HOME/**" }, { "path": "**" }]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-set-title",
    "core:window:allow-center",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "core:window:allow-is-maximized",
    "core:window:allow-toggle-maximize",
    "core:window:allow-set-focus",
    "core:window:allow-set-decorations",
    "core:window:allow-set-title-bar-style",
    "core:window:allow-start-dragging",
    "store:default",
    "notification:default",
    "os:default",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-open-url"
  ]
}
